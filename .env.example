# Database — PostgreSQL required (Vercel/serverless cannot use SQLite)
# Neon: https://neon.tech — use pooled connection for serverless:
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true&connect_timeout=15"

# NextAuth — required for production
NEXTAUTH_URL="http://localhost:3000"
# On Vercel set to: https://your-app.vercel.app (no trailing slash)
NEXTAUTH_SECRET="generate-a-strong-secret-with-openssl-rand-base64-32"

# Email (SendGrid SMTP)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
EMAIL_FROM="TrustHire <noreply@trusthire.com>"

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Cloudinary (optional — resume uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Vercel Blob (required for mentor content uploads)
BLOB_READ_WRITE_TOKEN=""
