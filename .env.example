# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/trusthire?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
