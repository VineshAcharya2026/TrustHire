generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  phone          String?        @unique
  passwordHash   String
  role           Role           @default(MENTEE)
  status         UserStatus     @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  profile        Profile?
  mentorProfile  MentorProfile?
  menteeProfile  MenteeProfile?
  auditLogs      AuditLog[]
  notifications  Notification[]
  loginEvents    LoginEvent[]
  mentorSessions    Mentorship[]       @relation("MentorUser")
  menteeSessions    Mentorship[]       @relation("MenteeUser")
  memberReflection  MemberReflection?
}

enum LeadershipLoneliness {
  FREQUENTLY
  OCCASIONALLY
  RARELY
  NEVER
}

enum GentleCommitment {
  YES_REFLECTS_INTENTIONS
  STILL_EXPLORING
}

model MemberReflection {
  id                        String                @id @default(cuid())
  userId                    String                @unique
  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  introduction              String?               @db.Text
  proudestAchievement       String?               @db.Text
  guidingValues             String?               @db.Text
  standFor                  String?               @db.Text
  admiredPerson             String?               @db.Text
  meaningPurpose            String?               @db.Text
  dreamMission              String?               @db.Text
  societalAspiration        String?               @db.Text
  othersDescribeYou         String?               @db.Text
  valuedQualities           String[]
  energizingPeople          String?               @db.Text
  differentBeliefsApproach  String?               @db.Text
  confidentialityImportance Int?
  supportWays               String[]
  contributions             String?               @db.Text
  leadershipLoneliness      LeadershipLoneliness?
  supportNeeded             String?               @db.Text
  sharingTopics             String?               @db.Text
  rememberedFor             String?               @db.Text
  additionalNotes           String?               @db.Text
  gentleCommitment          GentleCommitment?
  completedAt               DateTime?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
}

enum Role {
  SUPER_ADMIN
  MENTOR
  MENTEE
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  FROZEN
  DELETED
}

enum MentorshipStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  avatar    String?
  bio       String?
}

enum SeniorityLevel {
  MID
  SENIOR
  EXECUTIVE
  FOUNDER
}

enum CreditType {
  MENTORSHIP_COMPLETED
  RATING_BONUS
  NATION_BUILDING_OUTCOME
  FREE_MENTORSHIP
  CONTENT_PUBLISHED
  ADMIN_ADJUSTMENT
}

enum OutcomeType {
  PLACED
  PROMOTED
  STARTED_VENTURE
  CHANGED_INDUSTRY
  CHANGED_JOB
}

enum ContentType {
  POST
  PODCAST
  VIDEO
  IMAGE
}

enum InnerCircleStatus {
  PENDING
  APPROVED
  REJECTED
}

model MentorProfile {
  id                      String          @id @default(cuid())
  userId                  String          @unique
  user                    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company                 String?
  title                   String?
  expertise               String[]
  yearsExp                Int?
  maxMentees              Int             @default(5)
  linkedInUrl             String?
  city                    String?
  industry                String?
  seniorityLevel          SeniorityLevel?
  interests               String[]        @default([])
  isEliteFounder100       Boolean         @default(false)
  thoughtLeadershipScore  Int             @default(0)
  creditsBalance          Int             @default(0)
  offersFreeMentorship    Boolean         @default(false)
  skills                  MentorSkill[]
  content                 MentorContent[]
  creditLedger            CreditLedger[]
  ratingsReceived         MentorshipRating[] @relation("MentorRatings")
  innerCircleApplication  InnerCircleApplication?
}

model MenteeProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentRole   String?
  goals         String?
  desiredSkills String[]
}

model Mentorship {
  id                    String              @id @default(cuid())
  mentorId              String
  menteeId              String
  mentor                User                @relation("MentorUser", fields: [mentorId], references: [id], onDelete: Cascade)
  mentee                User                @relation("MenteeUser", fields: [menteeId], references: [id], onDelete: Cascade)
  status                MentorshipStatus    @default(PENDING)
  message               String?
  isFreeOrConcessional  Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  rating                MentorshipRating?
  outcomes              MentorshipOutcome[]
  creditEntries         CreditLedger[]

  @@unique([mentorId, menteeId])
}

model MentorSkill {
  id           String        @id @default(cuid())
  mentorId     String
  mentor       MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  skill        String
  masteryLevel Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([mentorId, skill])
}

model CreditLedger {
  id            String        @id @default(cuid())
  mentorId      String
  mentor        MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  amount        Int
  type          CreditType
  reason        String?
  mentorshipId  String?
  mentorship    Mentorship?   @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
}

model MentorshipRating {
  id            String     @id @default(cuid())
  mentorshipId  String     @unique
  mentorship    Mentorship @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  mentorId      String
  mentor        MentorProfile @relation("MentorRatings", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId      String
  rating        Int
  review        String?    @db.Text
  createdAt     DateTime   @default(now())
}

model MentorshipOutcome {
  id            String      @id @default(cuid())
  mentorshipId  String
  mentorship    Mentorship  @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  mentorId      String
  outcomeType   OutcomeType
  city          String?
  industry      String?
  notes         String?     @db.Text
  verified      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model MentorContent {
  id          String        @id @default(cuid())
  mentorId    String
  mentor      MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  type        ContentType
  title       String
  description String?       @db.Text
  fileUrl     String
  storageKey  String?
  mimeType    String?
  fileSize    Int?
  publishedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
}

model InnerCircleApplication {
  id                    String            @id @default(cuid())
  mentorId              String            @unique
  mentor                MentorProfile     @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  whyJoin               String?           @db.Text
  whatYouBring          String?           @db.Text
  nationBuildingCommit  String?           @db.Text
  thoughtLeadershipRefs String?           @db.Text
  gentleCommitment      Boolean           @default(false)
  status                InnerCircleStatus @default(PENDING)
  adminNotes            String?           @db.Text
  submittedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  role      Role
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Blacklist {
  id        String   @id @default(cuid())
  type      String
  value     String   @unique
  reason    String?
  addedBy   String
  createdAt DateTime @default(now())
}

model PlatformConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  read      Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
}
